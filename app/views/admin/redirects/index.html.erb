<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Redirects</h1>
  <%= link_to "+ New Redirect", new_admin_redirect_path, class: "bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700" %>
</div>

<% if @redirects.any? %>
  <div class="bg-white rounded-lg shadow">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Source</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Destination</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      
      <tbody class="bg-white divide-y divide-gray-200">
        <% @redirects.each do |redirect| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm font-medium text-gray-900">/<%= redirect.source %></div>
            </td>
            
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm text-gray-500"><%= redirect.destination %></div>
            </td>
            
            <td class="px-6 py-4 whitespace-nowrap">
              <% if redirect.active? %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Active</span>
              <% else %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">Inactive</span>
              <% end %>
            </td>
            
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <%= link_to "Edit", edit_admin_redirect_path(redirect), class: "text-indigo-600 hover:text-indigo-900 mr-3" %>
              <%= button_to "Delete", admin_redirect_path(redirect), method: :delete, 
                  data: { turbo_confirm: "Are you sure?" },
                  class: "text-red-600 hover:text-red-900 inline-block" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="bg-white rounded-lg shadow p-8 text-center">
    <p class="text-gray-500 mb-4">No redirects yet.</p>
    
    <div class="text-sm text-gray-600 mb-4">
      <p class="mb-2">Examples:</p>
      <ul class="list-disc list-inside">
        <li><code>/here</code> → <code>/contact</code></li>
        <li><code>/hiring</code> → <code>https://linkedin.com/in/yourname</code></li>
        <li><code>/github</code> → <code>https://github.com/yourusername</code></li>
      </ul>
    </div>
    
    <%= link_to "Create your first redirect", new_admin_redirect_path, class: "bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700" %>
  </div>
<% end %>
