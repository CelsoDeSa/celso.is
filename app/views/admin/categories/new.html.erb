<div class="max-w-4xl mx-auto">
  <div class="flex items-center mb-6">
    <%= link_to "&larr; Back", admin_categories_path, class: "text-gray-600 hover:text-gray-900 mr-4" %>
    <h1 class="text-2xl font-bold text-gray-900">New Category</h1>
  </div>

  <%= form_with model: [:admin, @category], class: "bg-white rounded-lg shadow p-6" do |f| %>
    <% if @category.errors.any? %>
      <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6">
        <h3 class="text-red-800 font-medium"><%= pluralize(@category.errors.count, "error") %> prohibited this category from being saved:</h3>
        <ul class="mt-2 text-red-700">
          <% @category.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500", placeholder: "e.g., Exploring" %>
    </div>

    <div class="mb-4">
      <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :description, rows: 2, 
          class: "w-full rounded-md border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500",
          placeholder: "Brief description of what this category is about" %>
    </div>

    <div class="mb-6">
      <%= f.label :position, "Order", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :position, 
          class: "w-full rounded-md border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500" %>
      <p class="text-xs text-gray-500 mt-1">Lower numbers appear first</p>
    </div>

    <div class="flex justify-end">
      <%= link_to "Cancel", admin_categories_path, class: "mr-4 px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" %>
      <%= f.submit "Create Category", class: "px-4 py-2 bg-purple-600 text-white rounded-md text-sm font-medium hover:bg-purple-700" %>
    </div>
  <% end %>
</div>
