<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Dashboard</h1>
  <p class="text-gray-600 mt-2">Welcome to your content management system.</p>
</div>

<!-- Stats Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <div class="bg-white rounded-lg shadow p-6">
    <div class="text-3xl font-bold text-blue-600"><%= @posts_count %></div>
    <div class="text-gray-600">Posts</div>
    <%= link_to "Manage Posts", admin_posts_path, class: "text-blue-600 hover:text-blue-800 text-sm mt-2 inline-block" %>
  </div>
  
  <div class="bg-white rounded-lg shadow p-6">
    <div class="text-3xl font-bold text-green-600"><%= @pages_count %></div>
    <div class="text-gray-600">Pages</div>
    <%= link_to "Manage Pages", admin_pages_path, class: "text-green-600 hover:text-green-800 text-sm mt-2 inline-block" %>
  </div>
  
  <div class="bg-white rounded-lg shadow p-6">
    <div class="text-3xl font-bold text-purple-600"><%= @categories_count %></div>
    <div class="text-gray-600">Categories</div>
    <%= link_to "Manage Categories", admin_categories_path, class: "text-purple-600 hover:text-purple-800 text-sm mt-2 inline-block" %>
  </div>
</div>

<!-- Quick Actions -->
<div class="bg-white rounded-lg shadow p-6 mb-8">
  <h2 class="text-xl font-bold text-gray-900 mb-4">Quick Actions</h2>
  
  <div class="flex flex-wrap gap-4">
    <%= link_to "+ New Post", new_admin_post_path, class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
    <%= link_to "+ New Page", new_admin_page_path, class: "bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700" %>
    <%= link_to "+ New Category", new_admin_category_path, class: "bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700" %>
    <%= link_to "+ New Redirect", new_admin_redirect_path, class: "bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700" %>
  </div>
</div>

<!-- Recent Posts -->
<% if @recent_posts.any? %>
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b">
      <h2 class="text-xl font-bold text-gray-900">Recent Posts</h2>
    </div>
    
    <div class="divide-y">
      <% @recent_posts.each do |post| %>
        <div class="px-6 py-4 flex items-center justify-between">
          <div>
            <div class="font-medium text-gray-900">
              <%= link_to post.title, edit_admin_post_path(post), class: "hover:text-blue-600" %>
            </div>
            <div class="text-sm text-gray-500">
              <%= post.category.name %> • 
              <%= post.published? ? "Published" : "Draft" %> • 
              <%= post.published_at.strftime("%b %d, %Y") %>
            </div>
          </div>
          
          <div class="flex space-x-2">
            <%= link_to "View", category_post_path(post.category, post), class: "text-blue-600 hover:text-blue-800 text-sm", target: "_blank" %>
            <%= link_to "Edit", edit_admin_post_path(post), class: "text-gray-600 hover:text-gray-800 text-sm" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
