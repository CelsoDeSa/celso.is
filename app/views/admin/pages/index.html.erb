<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Pages</h1>
  <%= link_to "+ New Page", new_admin_page_path, class: "bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700" %>
</div>

<% if @pages.any? %>
  <div class="bg-white rounded-lg shadow">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">URL</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Posts</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      
      <tbody class="bg-white divide-y divide-gray-200">
        <% @pages.each do |page| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm font-medium text-gray-900"><%= page.title %></div>
            </td>
            
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm text-gray-500">/<%= page.slug %></div>
            </td>
            
            <td class="px-6 py-4 whitespace-nowrap">
              <% if page.category? %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-purple-100 text-purple-800">Category</span>
              <% else %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">Static</span>
              <% end %>
            </td>
            
            <td class="px-6 py-4 whitespace-nowrap">
              <% if page.category? %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                  <%= page.posts.count %>
                </span>
              <% else %>
                <span class="text-gray-400">-</span>
              <% end %>
            </td>
            
            <td class="px-6 py-4 whitespace-nowrap">
              <% if page.published? %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Published</span>
              <% else %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">Draft</span>
              <% end %>
            </td>
            
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <%= link_to "View", page_path(page), class: "text-blue-600 hover:text-blue-900 mr-3", target: "_blank" %>
              <%= link_to "Edit", edit_admin_page_path(page), class: "text-indigo-600 hover:text-indigo-900 mr-3" %>
              <%= button_to "Delete", admin_page_path(page), method: :delete, 
                  data: { turbo_confirm: "Are you sure?#{ ' This will also delete all posts in this category.' if page.category? }" },
                  class: "text-red-600 hover:text-red-900 inline-block" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="bg-white rounded-lg shadow p-8 text-center">
    <p class="text-gray-500 mb-4">No pages yet.</p>
    <%= link_to "Create your first page", new_admin_page_path, class: "bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700" %>
  </div>
<% end %>
