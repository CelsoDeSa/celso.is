<div class="max-w-4xl mx-auto">
  <div class="flex items-center mb-6">
    <%= link_to "&larr; Back", admin_pages_path, class: "text-gray-600 hover:text-gray-900 mr-4" %>
    <h1 class="text-2xl font-bold text-gray-900">Edit Page</h1>
  </div>

  <%= form_with model: [:admin, @page], class: "bg-white rounded-lg shadow p-6" do |f| %>
    <% if @page.errors.any? %>
      <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6">
        <h3 class="text-red-800 font-medium"><%= pluralize(@page.errors.count, "error") %> prohibited this page from being saved:</h3>
        <ul class="mt-2 text-red-700">
          <% @page.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :title, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-green-500 focus:ring-green-500" %>
    </div>

    <div class="mb-4">
      <%= f.label :content, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.rich_text_area :content, class: "min-h-[400px]" %>
    </div>

    <div class="mb-4">
      <%= f.label :meta_description, "Meta Description (for SEO)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :meta_description, rows: 2, 
          class: "w-full rounded-md border-gray-300 shadow-sm focus:border-green-500 focus:ring-green-500" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
      <div>
        <%= f.label :published, "Published", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.check_box :published, class: "rounded border-gray-300 text-green-600 shadow-sm focus:border-green-500 focus:ring-green-500" %>
      </div>

      <div>
        <%= f.label :position, "Order", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :position, 
            class: "w-full rounded-md border-gray-300 shadow-sm focus:border-green-500 focus:ring-green-500" %>
      </div>
    </div>

    <div class="flex justify-between items-center">
      <div class="text-sm text-gray-500">
        URL: <code class="bg-gray-100 px-2 py-1 rounded">/<%= @page.slug %></code>
      </div>
      
      <div>
        <%= link_to "Cancel", admin_pages_path, class: "mr-4 px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" %>
        <%= f.submit "Update Page", class: "px-4 py-2 bg-green-600 text-white rounded-md text-sm font-medium hover:bg-green-700" %>
      </div>
    </div>
  <% end %>
</div>
