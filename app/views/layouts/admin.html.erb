<!DOCTYPE html>
<html>
  <head>
    <title>Admin - Celso.is</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100">
    <nav class="bg-gray-900 text-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex items-center justify-between h-16">
          <div class="flex items-center">
            <%= link_to "Celso.is Admin", admin_root_path, class: "text-xl font-bold" %>
          </div>
          
          <div class="flex space-x-4">
            <%= link_to "Dashboard", admin_root_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-700" %>
            <%= link_to "Posts", admin_posts_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-700" %>
            <%= link_to "Pages", admin_pages_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-700" %>
            <%= link_to "Redirects", admin_redirects_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-gray-700" %>
            <%= link_to "View Site", root_path, class: "px-3 py-2 rounded-md text-sm font-medium bg-blue-600 hover:bg-blue-700", target: "_blank" %>
          </div>
        </div>
      </div>
    </nav>
    
    <main class="max-w-7xl mx-auto px-4 py-8">
      <% if notice %>
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4" role="alert">
          <%= notice %>
        </div>
      <% end %>
      
      <% if alert %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4" role="alert">
          <%= alert %>
        </div>
      <% end %>
      
      <%= yield %>
    </main>
  </body>
</html>
