<div class="max-w-4xl mx-auto px-4 py-12">
  <header class="mb-12">
    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
      <%= @category.name %>
    </h1>
    
    <% if @category.description.present? %>
      <p class="text-xl text-gray-600">
        <%= @category.description %>
      </p>
    <% end %>
  </header>
  
  <% if @posts.any? %>
    <div class="grid gap-8">
      <% @posts.each do |post| %>
        <%= link_to category_post_path(@category, post), class: "block group" do %>
          <article class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow duration-300 p-6">
            <h2 class="text-2xl font-bold text-gray-900 group-hover:text-blue-600 transition-colors mb-3">
              <%= post.title %>
            </h2>
            
            <% if post.meta_description.present? %>
              <p class="text-gray-600 mb-3">
                <%= post.meta_description %>
              </p>
            <% else %>
              <p class="text-gray-600 mb-3">
                <%= strip_tags(post.content.to_s).truncate(150) %>
              </p>
            <% end %>
            
            <div class="text-sm text-gray-400">
              <%= post.published_at.strftime("%B %d, %Y") %>
            </div>
          </article>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <p class="text-gray-500 text-lg">No posts yet in this category.</p>
    </div>
  <% end %>
  
  <div class="mt-12 pt-8 border-t">
    <%= link_to root_path, class: "text-blue-600 hover:text-blue-800 font-medium" do %>
      &larr; Back to home
    <% end %>
  </div>
</div>
